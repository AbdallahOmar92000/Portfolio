<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardPost"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- User Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgUserProfilepost2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtUsernamepost2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textStyle="bold"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Post Body -->
        <TextView
            android:id="@+id/txtPostBodypost2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is a sample post body..."
            android:layout_marginTop="8dp"
            android:textSize="15sp" />

        <!-- Post Image -->

        <!--        <androidx.viewpager2.widget.ViewPager2-->
        <!--            android:id="@+id/viewPagerImages"-->
        <!--            android:layout_width="match_parent"-->
        <!--            android:layout_height="200dp"-->
        <!--            android:layout_marginTop="8dp"-->
        <!--            android:visibility="gone" />-->

        <LinearLayout
            android:id="@+id/imagesContainerpost2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:gravity="start"
            />

        <TextView
            android:id="@+id/tvShowMorepost2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ShowMore"
            android:textColor="@color/teal_200"
            android:visibility="visible"
            android:paddingTop="4dp" />


        <!-- Post Date -->
        <TextView
            android:id="@+id/txtPostDatepost2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 hours ago"
            android:textSize="12sp"
            android:textColor="#888888"
            android:layout_marginTop="6dp" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageButton
                android:id="@+id/btnLikepost2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Like"
                android:src="@drawable/ic_like"
                tools:ignore="TouchTargetSizeCheck" />
            <TextView
                android:id="@+id/txtlike_countpost2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginTop="8dp"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btndis_likepost2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Comment"
                android:src="@drawable/ic_dis_like"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/txtdislike_countpost2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginTop="8dp"
                android:textSize="15sp" />


        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>


