<?xml version="1.0" encoding="utf-8"?>
<!-- قسم التعليق -->
<LinearLayout android:id="@+id/commentSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Header: صورة المستخدم + الاسم + التاريخ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgUserProfileComm"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_user"
            android:scaleType="centerCrop"
            android:layout_marginEnd="6dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtUsernameComm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textStyle="bold"
                android:textColor="#1A73E8"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtCommentDateComm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2025-11-17 12:30"
                android:textSize="11sp"
                android:textColor="#777777" />
        </LinearLayout>
    </LinearLayout>

    <!-- نص التعليق -->
    <TextView
        android:id="@+id/txtCommentBodyComm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment Body..."
        android:layout_marginTop="6dp"
        android:textSize="15sp" />

<!--          <ImageView-->
<!--              android:id="@+id/imgCommentImageComm"-->
<!--              android:layout_width="match_parent"-->
<!--              android:layout_height="200dp"-->
<!--              android:visibility="gone"-->
<!--              android:scaleType="centerCrop"-->
<!--              android:layout_marginTop="6dp" />-->

    <LinearLayout
        android:id="@+id/imagesContainercomm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:gravity="start"
        />

    <!-- Like - Dislike - Reply -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <ImageButton
            android:id="@+id/btnLikecomm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Like"
            android:src="@drawable/ic_like"
            tools:ignore="TouchTargetSizeCheck" />
        <TextView
            android:id="@+id/txtlike_countcom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_marginTop="8dp"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btndis_likecomm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Comment"
            android:src="@drawable/ic_dis_like"
            tools:ignore="TouchTargetSizeCheck" />

        <TextView
            android:id="@+id/txtdislike_countcomm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_marginTop="8dp"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/btnReplyComm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reply"
            android:textColor="@color/purple_500"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- إضافة تعليق جديد -->
    <LinearLayout
        android:id="@+id/newCommentContainerComm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/edtNewCommentComm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Write a comment..."
            android:inputType="textMultiLine"
            android:minHeight="48dp"
            android:minLines="1"
            android:padding="8dp" />

        <Button
            android:id="@+id/btnSendCommentComm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>

