<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/replySection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/linesContainer"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/replyBubbleContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgProfileReply"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginTop="4dp"
                android:src="@drawable/ic_user" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_comment_bubble"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/txtUsernameReComm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="User Name"
                        android:textColor="@android:color/black"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtReCommentBodyReComm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="نص الرد..."
                        android:textColor="#1C1E21"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/imgReplyPhoto"
                        android:layout_width="200dp"
                        android:layout_height="180dp"
                        android:layout_marginTop="6dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:background="@drawable/bg_comment_bubble" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnLikeReply"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="إعجاب"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#65676B"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/btnReplyOnReply"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="رد"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#65676B" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/inputReplyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/edtReply"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="اكتب رداً..."
                    android:textSize="14sp"
                    android:padding="10dp"
                    android:background="@drawable/bg_comment_bubble" />

                <ImageButton
                    android:id="@+id/btnPickImage"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/add2"
                    android:scaleType="centerInside"
                    android:layout_marginStart="4dp"/>

                <Button
                    android:id="@+id/btnSendReply"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إرسال"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <!--        <ImageView-->
            <!--            android:id="@+id/imgPreviewReply"-->
            <!--            android:layout_width="120dp"-->
            <!--            android:layout_height="120dp"-->
            <!--            android:layout_marginTop="8dp"-->
            <!--            android:visibility="gone"-->
            <!--            android:scaleType="centerCrop"-->
            <!--            android:background="@drawable/bg_comment_bubble" />-->

            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgPreviewReply"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_comment_bubble" />

                <ImageButton
                    android:id="@+id/btnRemovePreview"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="top|end"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="#80000000"
                    android:contentDescription="Remove" />
            </FrameLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

